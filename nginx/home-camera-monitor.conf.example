server {
    listen 80;
    server_name _;   # 改成你的域名，或保持 _ 匹配任意 Host

    # 前端构建产物（deploy-all.sh: npm run build）
    root /service/home-camera-monitor/frontend/dist;
    index index.html;

    client_max_body_size 50m;

    # Django 静态资源（Swagger /admin）。必须放在 SPA try_files 之前
    location /static/ {
        alias /service/home-camera-monitor/backend/staticfiles/;
        access_log off;
        expires 7d;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8010/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /admin/ {
        proxy_pass http://127.0.0.1:8010/admin/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # MJPEG 备用预览（长连接，关闭缓冲）
    location /video_feed/ {
        proxy_pass http://127.0.0.1:8010/video_feed/;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 可选：把 MediaMTX WebRTC HTTP 挂到同源 /webrtc/
    # 启用后请将前端 VITE_WEBRTC_BASE_URL 设为 https://你的域名/webrtc
    # 注意：WebRTC ICE 仍使用 MediaMTX :8189/UDP，安全组需放行
    # location /webrtc/ {
    #     proxy_pass http://127.0.0.1:8889/;
    #     proxy_http_version 1.1;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header Upgrade $http_upgrade;
    #     proxy_set_header Connection "upgrade";
    #     proxy_read_timeout 3600;
    # }
}
