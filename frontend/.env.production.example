# 生产构建示例：复制为 frontend/.env.production 后再 npm run build
#
# Vite 会在构建时把这些值打进静态资源。

# 浏览器访问的 MediaMTX WebRTC 根地址（直连 :8889）
VITE_WEBRTC_BASE_URL=http://your.example.com:8889

# 若 Nginx 启用了 /webrtc/ 反代，改为同源，例如：
# VITE_WEBRTC_BASE_URL=https://your.example.com/webrtc

# 生产环境一般由 Nginx 同源反代 /api 与 /video_feed，无需再设：
# VITE_API_TARGET=
# VITE_VIDEO_FEED_TARGET=
