# Copy to .env.development for local overrides

# Django API (Vite proxy /api)
VITE_API_TARGET=http://localhost:8000

# WebRTC low-latency preview (MediaMTX :8889)
VITE_WEBRTC_BASE_URL=http://152.136.29.158:8889

# MJPEG fallback (/video_feed). Use remote server when local has no MediaMTX.
# VITE_VIDEO_FEED_TARGET=http://152.136.29.158

# 手机扫码录入使用的公网地址（生成二维码）；不设则用当前浏览器 origin
# VITE_PUBLIC_BASE_URL=http://152.136.29.158
