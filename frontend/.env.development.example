# Copy to .env.development for local overrides

# Django API (Vite proxy /api)
VITE_API_TARGET=http://localhost:8000

# WebRTC low-latency preview (MediaMTX :8889) — use your host if MediaMTX is remote
VITE_WEBRTC_BASE_URL=http://127.0.0.1:8889

# MJPEG fallback (/video_feed). Uncomment to point at a remote backend when needed.
# VITE_VIDEO_FEED_TARGET=http://127.0.0.1:8000
