# Copy to .env or export in shell before runserver
# PowerShell: Get-Content .env.example | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] } }

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Root@1234
DB_NAME=home_camera_monitor

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_ALLOWED_HOSTS=*

# 监控日报 AI（可选；未配置时使用规则模板生成）
# DAILY_REPORT_AI_API_KEY=sk-...
# DAILY_REPORT_AI_BASE_URL=https://api.openai.com/v1
# DAILY_REPORT_AI_MODEL=gpt-4o-mini
# DAILY_REPORT_AI_TIMEOUT=30
