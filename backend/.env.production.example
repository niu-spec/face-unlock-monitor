# 生产环境示例：复制为 backend/.env.production
#
#   cp backend/.env.example backend/.env.production
#   # 或直接复制本文件后修改

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=home_camera_monitor

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=your.example.com,127.0.0.1

# 本机 MediaMTX RTSP（Django / OpenCV 拉流）
RTSP_BASE_URL=rtsp://127.0.0.1:8554/stream
# 对外主机（MediaMTX WebRTC ICE / 文档用）；与下面 RTMP 主机保持一致
PUBLIC_HOST=your.example.com
# 对外展示的 RTMP 根地址（OBS 推流）
RTMP_PUBLIC_BASE_URL=rtmp://your.example.com:9090/stream

# gunicorn（也可由 systemd Environment= 覆盖）
BACKEND_BIND=127.0.0.1:8010
WORKERS=1
THREADS=16
TIMEOUT=300

# 可选：钉钉 / 日报 AI —— 见 .env.example
DINGTALK_ENABLED=False

# 生产环境前端域名（DEBUG=False 时生效），逗号分隔
# CORS_ALLOWED_ORIGINS=https://your.example.com
