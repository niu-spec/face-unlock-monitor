# Passwordless sudo rules for Jenkins CD (copy to server, then validate).
#
#   sudo visudo -cf /etc/sudoers.d/jenkins-deploy
#   sudo cp deploy/jenkins.sudoers.example /etc/sudoers.d/jenkins-deploy
#   sudo chmod 440 /etc/sudoers.d/jenkins-deploy
#
# If you use Baota panel, nginx is often at /www/server/nginx/sbin/nginx.
# Pick the paths that exist on your host (`which nginx`, `ls /etc/init.d/nginx`).

jenkins ALL=(ALL) NOPASSWD: \
  /bin/systemctl restart home-camera-backend, \
  /bin/systemctl reload nginx, \
  /bin/systemctl is-active nginx, \
  /usr/bin/nginx, \
  /usr/sbin/nginx, \
  /www/server/nginx/sbin/nginx, \
  /etc/init.d/nginx
